{#-
  LangSwitcher — locale picker (Ring 3 S3.3b-1).

  Composes DropdownMenu Ring 2 (Popover + Item) with consumer-provided
  locale options. On selection, the `lang-switcher` controller dispatches
  `lang-switcher:change` + persists to localStorage. Consumer wires actual
  page reload OR client-side i18n locale flip on the change event.

  Cross-controller compose: `data-controller="popover dropdown-menu lang-switcher"`.

  Parameters:
    htmlId          (string, optional)
    locales         (array,  required) — [{ code, label, flag? }]
    currentLocale   (string, optional, default 'fr')
    storageKey      (string, optional, default 'theme.locale')
    triggerVariant  (string, optional, default 'ghost')
    triggerSize     (string, optional, default 'sm')
    placement       (string, optional, default 'bottom')
-#}

{%- set htmlId         = htmlId         | default('cremona-lang-switcher-' ~ random()) -%}
{%- set currentLocale  = currentLocale  | default('fr') -%}
{%- set storageKey     = storageKey     | default('theme.locale') -%}
{%- set triggerVariant = triggerVariant | default('ghost') -%}
{%- set triggerSize    = triggerSize    | default('sm') -%}
{%- set placement      = placement      | default('bottom') -%}

{% embed '@cremona/components/dropdown-menu/dropdown-menu.html.twig' with {
  htmlId: htmlId ~ '-content',
  placement: placement,
  offset: 8,
  className: 'cremona-lang-switcher',
  contentClass: 'cremona-lang-switcher__content',
  controllerExtras: 'lang-switcher',
  attrs: {
    'data-lang-switcher-current-locale-value': currentLocale,
    'data-lang-switcher-storage-key-value': storageKey,
  },
} %}
  {% block trigger %}
    {% include '@cremona/components/button/button.html.twig' with {
      label: currentLocale | upper,
      variant: triggerVariant,
      size: triggerSize,
      iconTrailing: 'chevron-down',
      ariaLabel: 'theme.lang-switcher.aria.trigger'|trans,
      className: 'cremona-lang-switcher__trigger',
      labelAttrs: { 'data-lang-switcher-target': 'current' },
      attrs: {
        'data-popover-target': 'trigger',
        'aria-haspopup': 'menu',
        'aria-expanded': 'false',
        'aria-controls': popoverHtmlId,
      },
    } only %}
  {% endblock %}

  {% block items %}
    {% for locale in locales %}
      {% embed '@cremona/components/item/item.html.twig' with {
        as: 'div',
        className: 'cremona-lang-switcher__item',
        ariaCurrent: locale.code == currentLocale ? 'true' : null,
        attrs: {
          role: 'menuitem',
          tabindex: '-1',
          'data-action': 'click->lang-switcher#select',
          'data-locale': locale.code,
        },
      } %}
        {% block content %}
          {%- if locale.flag %}<span class="cremona-lang-switcher__flag" aria-hidden="true">{{ locale.flag }}</span>{% endif -%}
          <span class="cremona-lang-switcher__label">{{ locale.label }}</span>
        {% endblock %}
      {% endembed %}
    {% endfor %}
  {% endblock %}
{% endembed %}
