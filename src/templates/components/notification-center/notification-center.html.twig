{#-
  NotificationCenter — slide-over notifications panel (Ring 3).

  Composes Sheet Ring 2 (responsive : side-drawer desktop / bottom-sheet
  mobile) + Item rows + Badge unread + Avatar per row. Relative
  timestamps via consumer's format-date util at render time.

  Parameters:
    htmlId         (string, optional)
    edge           (string, optional)   — default 'end'
    title          (string, optional)
    notifications  (array, required)    — [{id, avatarUrl, title, body, timestamp, unread, href}]
    showMarkAll    (bool, optional)     — default true
-#}

{%- set htmlId        = htmlId        | default('cremona-notification-center-' ~ random()) -%}
{%- set edge          = edge          | default('end') -%}
{%- set title         = title         | default('theme.notification-center.title'|trans) -%}
{%- set notifications = notifications | default([]) -%}
{%- set showMarkAll   = showMarkAll   | default(true) -%}
{%- set unreadCount   = notifications | filter(n => n.unread) | length -%}
{%- set isEmpty       = notifications | length == 0 -%}

{% embed '@cremona/components/sheet/sheet.html.twig' with {
  htmlId: htmlId,
  edge: edge,
  sheetClassName: 'cremona-notification-center',
  closeButton: true,
  closeAriaLabel: 'theme.notification-center.close'|trans,
} %}
  {% block title %}
    {{- title -}}
    {%- if unreadCount > 0 -%}
      {% include '@cremona/components/badge/badge.html.twig' with {
        variant: 'primary',
        size: 'sm',
        count: unreadCount,
        className: 'cremona-notification-center__badge',
        attrs: { 'aria-label': 'theme.notification-center.unread-aria'|trans({'{count}': unreadCount}) },
      } only %}
    {%- endif -%}
  {% endblock %}

  {% block body %}
    {%- if isEmpty -%}
      <div class="cremona-notification-center__empty">
        {% include '@cremona/components/empty/empty.html.twig' with {
          size: 'md',
          icon: 'bell',
          title: 'theme.notification-center.empty.title'|trans,
          body: 'theme.notification-center.empty.body'|trans,
        } %}
      </div>
    {%- else -%}
      <ul class="cremona-notification-center__list">
        {%- for notif in notifications -%}
          <li class="cremona-notification-center__item"{% if notif.unread %} data-unread="true"{% endif %}>
            <a href="{{ notif.href }}"
               class="cremona-notification-center__item-link"
               data-action="click->notification-center#markRead"
               data-notification-id="{{ notif.id }}">
              {% include '@cremona/components/avatar/avatar.html.twig' with { src: notif.avatarUrl, alt: '', size: 'md' } only %}
              <div class="cremona-notification-center__item-body">
                <p class="cremona-notification-center__item-title">{{ notif.title }}</p>
                <p class="cremona-notification-center__item-text">{{ notif.body }}</p>
                <time class="cremona-notification-center__item-time" datetime="{{ notif.timestamp }}">{{ notif.relativeTime }}</time>
              </div>
              {%- if notif.unread -%}
                <span class="cremona-notification-center__unread-dot" aria-label="{{ 'theme.notification-center.unread'|trans }}"></span>
              {%- endif -%}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  {% endblock %}

  {% block footer %}{% if showMarkAll and unreadCount > 0 %}
    {% include '@cremona/components/button/button.html.twig' with {
      label: 'theme.notification-center.mark-all-read'|trans,
      variant: 'ghost',
      attrs: { 'data-action': 'click->notification-center#markAllRead' },
    } only %}
  {% endif %}{% endblock %}
{% endembed %}
