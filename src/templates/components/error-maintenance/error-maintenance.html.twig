{#-
  Error-Maintenance — "Maintenance in progress" page (Ring 3, brand-feel).

  Composes _error-shell (HERO variant) + Empty (lg, h1) + custom inline hero
  SVG via {% block illustration %} (consumer-overridable) + Button × 1-2.

  Microcopy:
    - title FR "Maintenance en cours" / EN "Maintenance in progress"
    - body  FR "On améliore Samurai en coulisses. Suivre l'avancement."
            EN "We're improving things behind the scenes. Track the status."

  See `docs/specs/ring3/Error-Maintenance.md` for the spec.
-#}

{%- set title          = title          | default('theme.error.maintenance.title'|trans) -%}
{%- set body           = body           | default('theme.error.maintenance.body'|trans) -%}
{%- set primaryLabel   = primaryLabel   | default('theme.error.maintenance.primary-cta'|trans) -%}
{%- set primaryHref    = primaryHref    | default('/status') -%}
{%- set secondaryLabel = secondaryLabel | default(null) -%}
{%- set secondaryHref  = secondaryHref  | default(null) -%}
{%- set htmlId         = htmlId         | default('cremona-error-maintenance') -%}
{%- set className      = className      | default('') -%}

{%- set _classes = ['cremona-error-maintenance'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{% embed '@cremona/components/_error-shell/_error-shell.html.twig' with {
  variant: 'hero',
  htmlId: htmlId,
  className: _classes | join(' '),
} %}
  {% block content %}
    {% embed '@cremona/components/empty/empty.html.twig' with {
      size: 'lg',
      titleLevel: 'h1',
      title: title,
      body: body,
      htmlId: htmlId ~ '-empty',
    } %}
      {% block illustration %}
        {# Hero illustration : wrench + gear motif on a soft surface.
           Consumer-overridable — wrap this pattern with their own
           {% block illustration %} via {% embed %}. #}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" aria-hidden="true" class="cremona-error-maintenance__hero">
          <defs>
            <linearGradient id="error-maintenance-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="var(--color-warning-soft)" stop-opacity="0.95"/>
              <stop offset="1" stop-color="var(--color-primary-soft)" stop-opacity="0.7"/>
            </linearGradient>
          </defs>
          <rect x="20" y="30" rx="14" ry="14" width="160" height="100" fill="url(#error-maintenance-grad)" stroke="var(--color-border-default)" stroke-width="2"/>
          {# Big gear, slightly off-center #}
          <g transform="translate(75 80)" stroke="var(--color-warning-soft-foreground)" stroke-width="3" stroke-linejoin="round" fill="none">
            <circle r="22"/>
            <circle r="8"/>
            <line x1="0" y1="-30" x2="0" y2="-22"/>
            <line x1="0" y1="22" x2="0" y2="30"/>
            <line x1="-30" y1="0" x2="-22" y2="0"/>
            <line x1="22" y1="0" x2="30" y2="0"/>
            <line x1="-21" y1="-21" x2="-16" y2="-16"/>
            <line x1="16" y1="16" x2="21" y2="21"/>
            <line x1="21" y1="-21" x2="16" y2="-16"/>
            <line x1="-16" y1="16" x2="-21" y2="21"/>
          </g>
          {# Small gear, top-right #}
          <g transform="translate(135 60)" stroke="var(--color-primary-soft-foreground)" stroke-width="2" stroke-linejoin="round" fill="none">
            <circle r="14"/>
            <circle r="5"/>
            <line x1="0" y1="-18" x2="0" y2="-14"/>
            <line x1="0" y1="14" x2="0" y2="18"/>
            <line x1="-18" y1="0" x2="-14" y2="0"/>
            <line x1="14" y1="0" x2="18" y2="0"/>
          </g>
        </svg>
      {% endblock %}

      {% block actions %}
        {% include '@cremona/components/button/button.html.twig' with {
          label: primaryLabel,
          variant: 'primary',
          size: 'md',
          href: primaryHref,
        } %}
        {% if secondaryLabel and secondaryHref %}
          {% include '@cremona/components/button/button.html.twig' with {
            label: secondaryLabel,
            variant: 'ghost',
            size: 'md',
            href: secondaryHref,
          } %}
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}
{% endembed %}
