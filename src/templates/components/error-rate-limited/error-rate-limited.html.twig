{#-
  Error-RateLimited — "Too many requests" page (Ring 3 S3.1c).

  Composes _error-shell (default) + Empty (lg, h1) + Icon `alert-triangle`
  (substitut per OQ-57b — visual: warning, too fast) + Button × 1 (primary
  "Réessayer").

  The body's `{minutes}` placeholder is consumer-interpolated via `t()`
  params on each render. Live countdown (Intl.RelativeTimeFormat →
  `rate-limit-countdown` controller ~30 lines) is deferred per S3.1
  trade-off log — see [STATE.md §"Trade-offs documented in S3.1"](../STATE.md).

  See `docs/specs/ring3/Error-404.md` §1 for shared Errors family doctrine.
-#}

{%- set title          = title          | default('theme.error.rate-limited.title'|trans) -%}
{%- set minutes        = minutes        | default(5) -%}
{%- set body           = body           | default('theme.error.rate-limited.body'|trans({'{minutes}': minutes})) -%}
{%- set primaryLabel   = primaryLabel   | default('theme.error.rate-limited.primary-cta'|trans) -%}
{%- set primaryHref    = primaryHref    | default('javascript:location.reload();') -%}
{%- set secondaryLabel = secondaryLabel | default(null) -%}
{%- set secondaryHref  = secondaryHref  | default(null) -%}
{%- set htmlId         = htmlId         | default('theme-error-rate-limited') -%}
{%- set className      = className      | default('') -%}

{%- set _classes = ['theme-error-rate-limited'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{% embed '@theme/components/_error-shell/_error-shell.html.twig' with {
  variant: 'default',
  htmlId: htmlId,
  className: _classes | join(' '),
} %}
  {% block content %}
    {% embed '@theme/components/empty/empty.html.twig' with {
      size: 'lg',
      titleLevel: 'h1',
      icon: 'alert-triangle',
      title: title,
      body: body,
      htmlId: htmlId ~ '-empty',
    } %}
      {% block actions %}
        {% include '@theme/components/button/button.html.twig' with {
          label: primaryLabel,
          variant: 'primary',
          size: 'md',
          href: primaryHref,
        } %}
        {% if secondaryLabel and secondaryHref %}
          {% include '@theme/components/button/button.html.twig' with {
            label: secondaryLabel,
            variant: 'ghost',
            size: 'md',
            href: secondaryHref,
          } %}
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}
{% endembed %}
