{#-
  Onboarding-Checklist — setup checklist with progress meter (Ring 3 S3.2).

  Compose Card + Progress + Checkbox × N. Consumer-server-side completion
  state (kit ships visual only).

  Parameters:
    htmlId  (string, optional)
    title   (string, required)
    items   (array, required)  — [{id, label, completed, disabled?}]
-#}

{%- set htmlId = htmlId | default('theme-onboarding-checklist-' ~ random()) -%}
{%- set total  = items | length -%}
{%- set done   = items | filter(i => i.completed) | length -%}
{%- set pct    = total > 0 ? (done * 100 / total) | round : 0 -%}
{%- set isAllDone = done == total and total > 0 -%}

{%- set _classes = ['theme-card', 'theme-onboarding-checklist'] -%}
{%- if isAllDone -%}{%- set _classes = _classes | merge(['theme-onboarding-checklist--complete']) -%}{%- endif -%}

<article class="{{ _classes | join(' ') }}" id="{{ htmlId }}" aria-labelledby="{{ htmlId }}-title">
  <header class="theme-card__header theme-onboarding-checklist__header">
    {% include '@theme/components/typography/typography.html.twig' with { as: 'h2', variant: 'h2', content: title, htmlId: htmlId ~ '-title', className: 'theme-onboarding-checklist__title' } only %}
    <p class="theme-onboarding-checklist__progress-text" aria-live="polite">
      {%- if isAllDone -%}
        {{ ('theme.onboarding.checklist.all-done')|trans }}
      {%- else -%}
        {{ ('theme.onboarding.checklist.progress')|trans({'{done}': done, '{total}': total}) }}
      {%- endif -%}
    </p>
    {% include '@theme/components/progress/progress.html.twig' with {
      value: pct,
      max: 100,
      className: 'theme-onboarding-checklist__progress',
      attrs: { 'aria-label': 'theme.onboarding.checklist.progress-aria'|trans },
    } only %}
  </header>

  <ul class="theme-onboarding-checklist__items">
    {%- for item in items -%}
      <li class="theme-onboarding-checklist__item"{% if item.completed %} data-completed="true"{% endif %}>
        <label class="theme-onboarding-checklist__label">
          {% include '@theme/components/checkbox/checkbox.html.twig' with {
            checked: item.completed,
            disabled: item.disabled | default(false),
            attrs: { 'aria-readonly': 'true', onclick: 'return false;' },
          } only %}
          <span class="theme-onboarding-checklist__item-label">{{ item.label }}</span>
        </label>
      </li>
    {%- endfor -%}
  </ul>
</article>
