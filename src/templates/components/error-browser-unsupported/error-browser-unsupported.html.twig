{#-
  Error-BrowserUnsupported — "Unsupported browser" page (Ring 3 S3.1c).

  Composes _error-shell (default) + Empty (lg, h1) + Icon `info` (substitut
  per OQ-57b — visual: informational guidance) + Button × 1 (primary "Mettre
  à jour mon navigateur").

  The primary CTA `href` points by default at a generic browser-update
  recommendation page. Consumer apps can override `primaryHref` with their
  own help-center URL.

  See `docs/specs/ring3/Error-404.md` §1 for shared Errors family doctrine.
-#}

{%- set title          = title          | default('theme.error.browser-unsupported.title'|trans) -%}
{%- set body           = body           | default('theme.error.browser-unsupported.body'|trans) -%}
{%- set primaryLabel   = primaryLabel   | default('theme.error.browser-unsupported.primary-cta'|trans) -%}
{%- set primaryHref    = primaryHref    | default('https://browsehappy.com/') -%}
{%- set secondaryLabel = secondaryLabel | default(null) -%}
{%- set secondaryHref  = secondaryHref  | default(null) -%}
{%- set htmlId         = htmlId         | default('cremona-error-browser-unsupported') -%}
{%- set className      = className      | default('') -%}

{%- set _classes = ['cremona-error-browser-unsupported'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{% embed '@cremona/components/_error-shell/_error-shell.html.twig' with {
  variant: 'default',
  htmlId: htmlId,
  className: _classes | join(' '),
} %}
  {% block content %}
    {% embed '@cremona/components/empty/empty.html.twig' with {
      size: 'lg',
      titleLevel: 'h1',
      icon: 'info',
      title: title,
      body: body,
      htmlId: htmlId ~ '-empty',
    } %}
      {% block actions %}
        {% include '@cremona/components/button/button.html.twig' with {
          label: primaryLabel,
          variant: 'primary',
          size: 'md',
          href: primaryHref,
        } %}
        {% if secondaryLabel and secondaryHref %}
          {% include '@cremona/components/button/button.html.twig' with {
            label: secondaryLabel,
            variant: 'ghost',
            size: 'md',
            href: secondaryHref,
          } %}
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}
{% endembed %}
