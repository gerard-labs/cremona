{#-
  Spinner — pure-SVG rotating arc.

  Parameters:
    size      (string, optional) xs (12) | sm (16) | md (default 20) | lg (24) | xl (32)
    label     (string, optional) accessible label; defaults to the localized
                                 "Chargement" / "Loading" via the consumer's translator.
                                 If null AND the consumer doesn't pass the key, the
                                 Spinner falls back to the literal `loading_aria_label`
                                 placeholder so SR users still get a name.
    inverted  (bool,   optional) default false. true → uses primary-foreground (for
                                 use on a primary-colored surface like a primary button).
    className (string, optional)

  Accessibility: the visible <svg> is aria-hidden; the announcement is carried by an
  sr-only <span> inside the outer span (which has role=status + aria-live=polite so
  the label is announced).
-#}

{%- set size      = size      | default('md') -%}
{%- set label     = label     | default(null) -%}
{%- set inverted  = inverted  | default(false) -%}
{%- set className = className | default('') -%}

{%- set _classes = ['cremona-spinner'] -%}
{%- if inverted -%}{%- set _classes = _classes | merge(['cremona-spinner--inverted']) -%}{%- endif -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

<span class="{{ _classes | join(' ') }}" data-size="{{ size }}" role="status" aria-live="polite">
  <svg viewBox="0 0 50 50" aria-hidden="true" focusable="false">
    <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" pathLength="100" stroke-dasharray="25 75"></circle>
  </svg>
  <span class="cremona-sr-only">{{ label }}</span>
</span>
