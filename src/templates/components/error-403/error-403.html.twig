{#-
  Error-403 — "Access denied" page (Ring 3).

  Composes _error-shell (default) + Empty (lg, h1) + Icon `eye` (substitute)
  + Button × {1, optional 2}.

  See `docs/specs/ring3/Error-404.md` §1 for shared Errors family doctrine.
-#}

{%- set title          = title          | default('theme.error.403.title'|trans) -%}
{%- set body           = body           | default('theme.error.403.body'|trans) -%}
{%- set primaryLabel   = primaryLabel   | default('theme.error.403.primary-cta'|trans) -%}
{%- set primaryHref    = primaryHref    | default('/') -%}
{%- set secondaryLabel = secondaryLabel | default('theme.error.403.secondary-cta'|trans) -%}
{%- set secondaryHref  = secondaryHref  | default(null) -%}
{%- set htmlId         = htmlId         | default('cremona-error-403') -%}
{%- set className      = className      | default('') -%}

{%- set _classes = ['cremona-error-403'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{% embed '@cremona/components/_error-shell/_error-shell.html.twig' with {
  variant: 'default',
  htmlId: htmlId,
  className: _classes | join(' '),
} %}
  {% block content %}
    {% embed '@cremona/components/empty/empty.html.twig' with {
      size: 'lg',
      titleLevel: 'h1',
      icon: 'eye',
      title: title,
      body: body,
      htmlId: htmlId ~ '-empty',
    } %}
      {% block actions %}
        {% include '@cremona/components/button/button.html.twig' with {
          label: primaryLabel,
          variant: 'primary',
          size: 'md',
          href: primaryHref,
        } %}
        {% if secondaryHref %}
          {% include '@cremona/components/button/button.html.twig' with {
            label: secondaryLabel,
            variant: 'ghost',
            size: 'md',
            href: secondaryHref,
          } %}
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}
{% endembed %}
