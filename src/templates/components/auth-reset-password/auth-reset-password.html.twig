{#-
  Auth-ResetPassword — reset-password pattern (Ring 3 S3.1).

  Composes _auth-shell + Field + Input + Button + Alert + Empty.
  Pure server-rendered form (OQ-55). 0 Stimulus controller.

  Token-bound : accessed via a tokenized URL from the password-reset email.
  The server validates the token before rendering ; expired/used tokens
  switch the body to a terminal Empty state.

  See `docs/specs/ring3/Auth-ResetPassword.md`.
-#}

{%- set title              = title              | default('theme.auth.reset-password.title'|trans) -%}
{%- set subtitle           = subtitle           | default('theme.auth.reset-password.subtitle'|trans) -%}
{%- set formAction         = formAction         | default('#') -%}
{%- set csrfToken          = csrfToken          | default(null) -%}
{%- set csrfFieldName      = csrfFieldName      | default('_token') -%}
{%- set resetToken         = resetToken         | default(null) -%}
{%- set passwordLabel      = passwordLabel      | default('theme.auth.reset-password.password'|trans) -%}
{%- set passwordPlaceholder= passwordPlaceholder| default('theme.auth.reset-password.password-placeholder'|trans) -%}
{%- set passwordHelp       = passwordHelp       | default('theme.auth.reset-password.password-help'|trans) -%}
{%- set passwordError      = passwordError      | default(null) -%}
{%- set confirmLabel       = confirmLabel       | default('theme.auth.reset-password.confirm'|trans) -%}
{%- set confirmError       = confirmError       | default(null) -%}
{%- set submitLabel        = submitLabel        | default('theme.auth.reset-password.submit'|trans) -%}
{%- set loading            = loading            | default(false) -%}
{%- set backToLoginHref    = backToLoginHref    | default(null) -%}
{%- set backToLoginLabel   = backToLoginLabel   | default('theme.auth.reset-password.back-to-login'|trans) -%}
{%- set globalError        = globalError        | default(null) -%}
{%- set tokenExpired       = tokenExpired       | default(false) -%}
{%- set tokenUsed          = tokenUsed          | default(false) -%}
{%- set htmlId             = htmlId             | default('cremona-auth-reset-password') -%}
{%- set className          = className          | default('') -%}

{%- set _formClasses = ['cremona-auth-reset-password'] -%}
{%- if className -%}{%- set _formClasses = _formClasses | merge([className]) -%}{%- endif -%}

{%- set _state = 'default' -%}
{%- if tokenExpired -%}{%- set _state = 'error-token-expired' -%}
{%- elseif tokenUsed -%}{%- set _state = 'error-token-used' -%}
{%- elseif loading -%}{%- set _state = 'loading' -%}
{%- elseif globalError or passwordError or confirmError -%}{%- set _state = 'error' -%}
{%- endif -%}

{% embed '@cremona/components/_auth-shell/_auth-shell.html.twig' with {
  title: title,
  subtitle: subtitle,
  htmlId: htmlId,
  variant: 'default',
} %}
  {% block content %}
    {% if tokenExpired %}
      {% embed '@cremona/components/empty/empty.html.twig' with {
        title: 'theme.auth.reset-password.token-expired.title'|trans,
        body: 'theme.auth.reset-password.token-expired.body'|trans,
        icon: 'alert-circle',
        size: 'md',
        titleLevel: 'h2',
        htmlId: htmlId ~ '-token-expired',
      } %}
        {% block actions %}
          {% include '@cremona/components/button/button.html.twig' with {
            label: 'theme.auth.reset-password.token-expired.cta'|trans,
            variant: 'primary',
            size: 'md',
            href: '/password/forgot',
          } %}
        {% endblock %}
      {% endembed %}
    {% elseif tokenUsed %}
      {% embed '@cremona/components/empty/empty.html.twig' with {
        title: 'theme.auth.reset-password.token-used.title'|trans,
        body: 'theme.auth.reset-password.token-used.body'|trans,
        icon: 'info',
        size: 'md',
        titleLevel: 'h2',
        htmlId: htmlId ~ '-token-used',
      } %}
        {% block actions %}
          {% include '@cremona/components/button/button.html.twig' with {
            label: 'theme.auth.reset-password.token-used.cta'|trans,
            variant: 'primary',
            size: 'md',
            href: '/login',
          } %}
        {% endblock %}
      {% endembed %}
    {% else %}
      <form
        class="{{ _formClasses | join(' ') }}"
        action="{{ formAction }}"
        method="post"
        novalidate
        data-state="{{ _state }}"
        {%- if loading %} data-loading="true"{% endif -%}
      >
        {% if globalError %}
          {% include '@cremona/components/alert/alert.html.twig' with {
            variant: 'danger',
            tone: 'soft',
            body: globalError,
            htmlId: htmlId ~ '-global-error',
          } %}
        {% endif %}

        {% if csrfToken %}
          <input type="hidden" name="{{ csrfFieldName }}" value="{{ csrfToken }}">
        {% endif %}

        {% if resetToken %}
          <input type="hidden" name="reset_token" value="{{ resetToken }}">
        {% endif %}

        {% embed '@cremona/components/field/field.html.twig' with {
          label: passwordLabel,
          htmlId: htmlId ~ '-password',
          required: true,
          help: passwordHelp,
          error: passwordError,
        } %}
          {% block control %}
            {% include '@cremona/components/input/input.html.twig' with {
              htmlId: fieldHtmlId,
              describedBy: fieldDescribedBy,
              invalid: fieldInvalid,
              required: fieldRequired,
              disabled: fieldDisabled,
              type: 'password',
              name: 'password',
              placeholder: passwordPlaceholder,
              autocomplete: 'new-password',
              minlength: 8,
            } %}
          {% endblock %}
        {% endembed %}

        {% embed '@cremona/components/field/field.html.twig' with {
          label: confirmLabel,
          htmlId: htmlId ~ '-confirm',
          required: true,
          error: confirmError,
        } %}
          {% block control %}
            {% include '@cremona/components/input/input.html.twig' with {
              htmlId: fieldHtmlId,
              describedBy: fieldDescribedBy,
              invalid: fieldInvalid,
              required: fieldRequired,
              disabled: fieldDisabled,
              type: 'password',
              name: 'confirm',
              autocomplete: 'new-password',
              minlength: 8,
            } %}
          {% endblock %}
        {% endembed %}

        {% include '@cremona/components/button/button.html.twig' with {
          label: submitLabel,
          variant: 'primary',
          size: 'md',
          type: 'submit',
          loading: loading,
          fullWidth: true,
        } %}
      </form>
    {% endif %}
  {% endblock %}

  {% if backToLoginHref and not (tokenExpired or tokenUsed) %}
    {% block footer %}
      {% include '@cremona/components/button/button.html.twig' with {
        label: backToLoginLabel,
        variant: 'link',
        size: 'md',
        href: backToLoginHref,
        iconLeading: 'arrow-left',
      } %}
    {% endblock %}
  {% endif %}
{% endembed %}
