{#-
  Onboarding-WelcomeScreens — multi-step welcome flow post-Register (Ring 3 S3.2).

  Composes Card Ring 1 (panel) + Stepper Ring 2 (progress + step machine)
  + Button Ring 1 × 3 (Skip / Previous / Next / Finish).

  Microcopy verbatim from [12-microcopy-tone §Onboarding] :
    "Bienvenue. Configurons ton workspace en 2 minutes."
    Skip: "Plus tard" | Done: "C'est parti."

  Parameters:
    htmlId        (string, optional)
    title         (string, required)
    steps         (array, required)   — [{heading, body, icon}]
    currentStep   (int, optional)     — default 0 (0-indexed)
    skipHref      (string, optional)  — default null = button (consumer wires action)
    finishHref    (string, optional)  — default null
-#}

{%- set htmlId      = htmlId      | default('cremona-onboarding-welcome-' ~ random()) -%}
{%- set currentStep = currentStep | default(0) -%}
{%- set skipHref    = skipHref    | default(null) -%}
{%- set finishHref  = finishHref  | default(null) -%}

{%- set totalSteps  = steps | length -%}
{%- set isFirst     = currentStep == 0 -%}
{%- set isLast      = currentStep == totalSteps - 1 -%}
{%- set step        = steps[currentStep] -%}

<main class="cremona-onboarding-welcome-screens" id="{{ htmlId }}">
  {%- set _stepperSteps = [] -%}
  {%- for s in steps -%}
    {%- set _stepperSteps = _stepperSteps | merge([{ label: s.heading }]) -%}
  {%- endfor -%}

  {% embed '@cremona/components/card/card.html.twig' with {
    htmlId: null,
    className: 'cremona-onboarding-welcome-screens__card',
    headerClass: 'cremona-onboarding-welcome-screens__header',
    bodyClass: 'cremona-onboarding-welcome-screens__body',
    footerClass: 'cremona-onboarding-welcome-screens__footer',
  } %}
    {% block header %}
      {% include '@cremona/components/typography/typography.html.twig' with { as: 'h1', variant: 'h1', content: title, className: 'cremona-onboarding-welcome-screens__title' } only %}
      <nav class="cremona-onboarding-welcome-screens__stepper" aria-label="{{ 'theme.onboarding.welcome-screens.stepper.aria'|trans }}">
        {% include '@cremona/components/stepper/stepper.html.twig' with {
          steps: _stepperSteps,
          currentStep: currentStep + 1,
          orientation: 'horizontal',
          label: 'theme.onboarding.welcome-screens.stepper.aria'|trans,
        } only %}
      </nav>
    {% endblock %}

    {% block body %}
      <div class="cremona-onboarding-welcome-screens__step-icon" aria-hidden="true">
        {% include '@cremona/components/icon/icon.html.twig' with { name: step.icon, size: 'lg' } %}
      </div>
      {% include '@cremona/components/typography/typography.html.twig' with { as: 'h2', variant: 'h2', content: step.heading, className: 'cremona-onboarding-welcome-screens__step-heading' } only %}
      <p class="cremona-onboarding-welcome-screens__step-body">{{ step.body }}</p>
    {% endblock %}

    {% block footer %}
      {% include '@cremona/components/button/button.html.twig' with {
        label: 'theme.onboarding.welcome-screens.skip'|trans,
        variant: 'ghost',
        href: skipHref,
        className: 'cremona-onboarding-welcome-screens__skip',
        attrs: skipHref ? {} : { 'data-action': 'click->stepper#skip' },
      } only %}

      <div class="cremona-onboarding-welcome-screens__nav">
        {%- if not isFirst -%}
          {% include '@cremona/components/button/button.html.twig' with {
            label: 'theme.onboarding.welcome-screens.previous'|trans,
            variant: 'outline',
            attrs: { 'data-action': 'click->stepper#previous' },
          } only %}
        {%- endif -%}

        {%- if isLast -%}
          {% include '@cremona/components/button/button.html.twig' with {
            label: 'theme.onboarding.welcome-screens.finish'|trans,
            variant: 'primary',
            href: finishHref,
            attrs: finishHref ? {} : { 'data-action': 'click->stepper#finish' },
          } only %}
        {%- else -%}
          {% include '@cremona/components/button/button.html.twig' with {
            label: 'theme.onboarding.welcome-screens.next'|trans,
            variant: 'primary',
            attrs: { 'data-action': 'click->stepper#next' },
          } only %}
        {%- endif -%}
      </div>
    {% endblock %}
  {% endembed %}
</main>
