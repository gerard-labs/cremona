{#-
  Auth-ForgotPassword — password-reset request pattern (Ring 3).

  Composes _auth-shell + Field + Input + Button + Alert + Empty.
  Pure server-rendered form. 0 Stimulus controller.

  Anti-enumeration : the success body phrasing deliberately says "if the
  email matches an account" — never confirms whether the email exists.
  Canonical security doctrine (Stripe / Vercel / Notion).

  See `docs/specs/ring3/Auth-ForgotPassword.md` for full state matrix.
-#}

{%- set title              = title              | default('theme.auth.forgot-password.title'|trans) -%}
{%- set subtitle           = subtitle           | default('theme.auth.forgot-password.subtitle'|trans) -%}
{%- set formAction         = formAction         | default('#') -%}
{%- set csrfToken          = csrfToken          | default(null) -%}
{%- set csrfFieldName      = csrfFieldName      | default('_token') -%}
{%- set emailLabel         = emailLabel         | default('theme.auth.forgot-password.email'|trans) -%}
{%- set emailPlaceholder   = emailPlaceholder   | default('theme.auth.forgot-password.email-placeholder'|trans) -%}
{%- set emailValue         = emailValue         | default(null) -%}
{%- set emailError         = emailError         | default(null) -%}
{%- set submitLabel        = submitLabel        | default('theme.auth.forgot-password.submit'|trans) -%}
{%- set loading            = loading            | default(false) -%}
{%- set backToLoginHref    = backToLoginHref    | default(null) -%}
{%- set backToLoginLabel   = backToLoginLabel   | default('theme.auth.forgot-password.back-to-login'|trans) -%}
{%- set globalError        = globalError        | default(null) -%}
{%- set rateLimitedNotice  = rateLimitedNotice  | default(null) -%}
{%- set successState       = successState       | default(false) -%}
{%- set successTitle       = successTitle       | default('theme.auth.forgot-password.success.title'|trans) -%}
{%- set successBody        = successBody        | default('theme.auth.forgot-password.success.body'|trans) -%}
{%- set successResendHref  = successResendHref  | default(null) -%}
{%- set successResendLabel = successResendLabel | default('theme.auth.forgot-password.success.resend'|trans) -%}
{%- set htmlId             = htmlId             | default('cremona-auth-forgot-password') -%}
{%- set className          = className          | default('') -%}

{%- set _formClasses = ['cremona-auth-forgot-password'] -%}
{%- if className -%}{%- set _formClasses = _formClasses | merge([className]) -%}{%- endif -%}

{%- set _state = 'default' -%}
{%- if successState -%}{%- set _state = 'success' -%}
{%- elseif loading -%}{%- set _state = 'loading' -%}
{%- elseif rateLimitedNotice -%}{%- set _state = 'error-rate-limited' -%}
{%- elseif globalError or emailError -%}{%- set _state = 'error' -%}
{%- endif -%}

{% embed '@cremona/components/_auth-shell/_auth-shell.html.twig' with {
  title: title,
  subtitle: subtitle,
  htmlId: htmlId,
  variant: 'default',
} %}
  {% block content %}
    {% if successState %}
      {% embed '@cremona/components/empty/empty.html.twig' with {
        title: successTitle,
        body: successBody,
        icon: 'mail',
        size: 'md',
        titleLevel: 'h2',
        htmlId: htmlId ~ '-success',
      } %}
        {% if successResendHref %}
          {% block actions %}
            {% include '@cremona/components/button/button.html.twig' with {
              label: successResendLabel,
              variant: 'secondary',
              size: 'md',
              href: successResendHref,
            } %}
          {% endblock %}
        {% endif %}
      {% endembed %}
    {% else %}
      <form
        class="{{ _formClasses | join(' ') }}"
        action="{{ formAction }}"
        method="post"
        novalidate
        data-state="{{ _state }}"
        {%- if loading %} data-loading="true"{% endif -%}
      >
        {% if globalError %}
          {% include '@cremona/components/alert/alert.html.twig' with {
            variant: 'danger',
            tone: 'soft',
            body: globalError,
            htmlId: htmlId ~ '-global-error',
          } %}
        {% endif %}

        {% if rateLimitedNotice %}
          {% include '@cremona/components/alert/alert.html.twig' with {
            variant: 'warning',
            tone: 'soft',
            body: rateLimitedNotice,
            htmlId: htmlId ~ '-rate-limited',
          } %}
        {% endif %}

        {% if csrfToken %}
          <input type="hidden" name="{{ csrfFieldName }}" value="{{ csrfToken }}">
        {% endif %}

        {% embed '@cremona/components/field/field.html.twig' with {
          label: emailLabel,
          htmlId: htmlId ~ '-email',
          required: true,
          error: emailError,
        } %}
          {% block control %}
            {% include '@cremona/components/input/input.html.twig' with {
              htmlId: fieldHtmlId,
              describedBy: fieldDescribedBy,
              invalid: fieldInvalid,
              required: fieldRequired,
              disabled: fieldDisabled,
              type: 'email',
              name: 'email',
              value: emailValue,
              placeholder: emailPlaceholder,
              autocomplete: 'email',
              inputmode: 'email',
              spellcheck: 'false',
            } %}
          {% endblock %}
        {% endembed %}

        {% include '@cremona/components/button/button.html.twig' with {
          label: submitLabel,
          variant: 'primary',
          size: 'md',
          type: 'submit',
          loading: loading,
          disabled: rateLimitedNotice ? true : false,
          fullWidth: true,
        } %}
      </form>
    {% endif %}
  {% endblock %}

  {% if backToLoginHref %}
    {% block footer %}
      {% include '@cremona/components/button/button.html.twig' with {
        label: backToLoginLabel,
        variant: 'link',
        size: 'md',
        href: backToLoginHref,
        iconLeading: 'arrow-left',
      } %}
    {% endblock %}
  {% endif %}
{% endembed %}
