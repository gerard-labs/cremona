{#-
  Error-503 — "Service unavailable" page (Ring 3 S3.1c).

  Composes _error-shell (default) + Empty (lg, h1) + Icon `alert-triangle`
  (in curated 30-set, direct match) + Button × 1 (primary "Réessayer").

  See `docs/specs/ring3/Error-404.md` §1 for shared Errors family doctrine.
-#}

{%- set title         = title         | default('theme.error.503.title'|trans) -%}
{%- set body          = body          | default('theme.error.503.body'|trans) -%}
{%- set primaryLabel  = primaryLabel  | default('theme.error.503.primary-cta'|trans) -%}
{%- set primaryHref   = primaryHref   | default('javascript:location.reload();') -%}
{%- set secondaryLabel = secondaryLabel | default(null) -%}
{%- set secondaryHref = secondaryHref | default(null) -%}
{%- set htmlId        = htmlId        | default('cremona-error-503') -%}
{%- set className     = className     | default('') -%}

{%- set _classes = ['cremona-error-503'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{% embed '@cremona/components/_error-shell/_error-shell.html.twig' with {
  variant: 'default',
  htmlId: htmlId,
  className: _classes | join(' '),
} %}
  {% block content %}
    {% embed '@cremona/components/empty/empty.html.twig' with {
      size: 'lg',
      titleLevel: 'h1',
      icon: 'alert-triangle',
      title: title,
      body: body,
      htmlId: htmlId ~ '-empty',
    } %}
      {% block actions %}
        {% include '@cremona/components/button/button.html.twig' with {
          label: primaryLabel,
          variant: 'primary',
          size: 'md',
          href: primaryHref,
        } %}
        {% if secondaryLabel and secondaryHref %}
          {% include '@cremona/components/button/button.html.twig' with {
            label: secondaryLabel,
            variant: 'ghost',
            size: 'md',
            href: secondaryHref,
          } %}
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}
{% endembed %}
