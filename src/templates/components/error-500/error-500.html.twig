{#-
  Error-500 — "Server error" page (Ring 3 S3.1c).

  Composes _error-shell (default) + Empty (lg, h1) + Icon `alert-circle` (in
  curated 30-set, direct match) + Button × 2 (primary "Réessayer" + secondary
  "Retour à l'accueil").

  Microcopy verbatim from [12-microcopy-tone.md §"Messages d'erreur" §500] :
    - title FR "Quelque chose s'est mal passé." / EN "Something went wrong."
    - body  FR "On enquête côté serveur. Réessaie dans quelques instants."
            EN "We're investigating on our end. Try again in a moment."

  See `docs/specs/ring3/Error-404.md` §1 for shared Errors family doctrine.
-#}

{%- set title          = title          | default('theme.error.500.title'|trans) -%}
{%- set body           = body           | default('theme.error.500.body'|trans) -%}
{%- set primaryLabel   = primaryLabel   | default('theme.error.500.primary-cta'|trans) -%}
{%- set primaryHref    = primaryHref    | default('javascript:location.reload();') -%}
{%- set secondaryLabel = secondaryLabel | default('theme.error.500.secondary-cta'|trans) -%}
{%- set secondaryHref  = secondaryHref  | default('/') -%}
{%- set htmlId         = htmlId         | default('theme-error-500') -%}
{%- set className      = className      | default('') -%}

{%- set _classes = ['theme-error-500'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{% embed '@theme/components/_error-shell/_error-shell.html.twig' with {
  variant: 'default',
  htmlId: htmlId,
  className: _classes | join(' '),
} %}
  {% block content %}
    {% embed '@theme/components/empty/empty.html.twig' with {
      size: 'lg',
      titleLevel: 'h1',
      icon: 'alert-circle',
      title: title,
      body: body,
      htmlId: htmlId ~ '-empty',
    } %}
      {% block actions %}
        {% include '@theme/components/button/button.html.twig' with {
          label: primaryLabel,
          variant: 'primary',
          size: 'md',
          href: primaryHref,
        } %}
        {% if secondaryHref %}
          {% include '@theme/components/button/button.html.twig' with {
            label: secondaryLabel,
            variant: 'ghost',
            size: 'md',
            href: secondaryHref,
          } %}
        {% endif %}
      {% endblock %}
    {% endembed %}
  {% endblock %}
{% endembed %}
