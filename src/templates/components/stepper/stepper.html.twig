{#-
  Stepper — step-by-step progress indicator (declarative, consumer-driven).

  Per the mini-OQ Stepper resolution sealed at S2.8 opening :
    - Pure declarative — consumer drives `currentStep` via the value attribute.
    - No setStep / next / prev API surface — consumer manages state externally.

  Composes the `stepper` Stimulus controller (stamps data-state + aria-current
  per step based on currentStep ; dispatches `stepper:step-change` on transition).

  Variants:
    - `orientation: 'horizontal'` (default) — steps in a row, connectors between.
    - `orientation: 'vertical'` — steps stacked, connectors vertical.

  Sizes : sm (28 px indicator) / md (default, 36 px) / lg (44 px) via `size`.

  Parameters:
    htmlId       (string,  optional) — auto-generated.
    steps        (array,   required) — list of step descriptors :
                                       { label, description?, disabled? }.
                                       The order in the array determines the
                                       step index (1-based). `description`
                                       collapses to display:none under 576 px
                                       in horizontal orientation.
    currentStep  (int,     optional) — 1-indexed active step (default 1).
    totalSteps   (int,     optional) — total step count (default = steps.length).
    orientation  (string,  optional) — horizontal (default) | vertical.
    size         (string,  optional) — sm | md (default) | lg.
    label        (string,  optional) — aria-label for the ordered list
                                       (default 'Étapes').
    className    (string,  optional)

  Usage:

    {% include '@cremona/components/stepper/stepper.html.twig' with {
      currentStep: 2,
      label: 'Création de compte'|trans,
      steps: [
        { label: 'Compte'|trans,        description: 'Email + mot de passe'|trans },
        { label: 'Profil'|trans,        description: 'Nom + avatar'|trans },
        { label: 'Préférences'|trans,   description: 'Thème + langue'|trans },
        { label: 'Confirmation'|trans },
      ],
    } %}

  Events (dispatched on the <ol>):
    stepper:step-change — detail.{ currentStep, previousStep, totalSteps, completed }
-#}

{%- set htmlId       = htmlId       | default('cremona-stepper-' ~ random()) -%}
{%- set steps        = steps        | default([]) -%}
{%- set currentStep  = currentStep  | default(1) -%}
{%- set totalSteps   = totalSteps   | default(steps | length) -%}
{%- set orientation  = orientation  | default('horizontal') -%}
{%- set size         = size         | default('md') -%}
{%- set label        = label        | default('Étapes') -%}
{%- set className    = className    | default('') -%}
{%- set controllerless = controllerless | default(false) -%}

{%- set _classes = ['cremona-stepper'] -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

<ol
  id="{{ htmlId }}"
  class="{{ _classes | join(' ') }}"
  {%- if not controllerless %}
  data-controller="stepper"
  data-stepper-current-step-value="{{ currentStep }}"
  data-stepper-total-steps-value="{{ totalSteps }}"
  {%- endif %}
  data-orientation="{{ orientation }}"
  data-size="{{ size }}"
  aria-label="{{ label }}"
>
  {%- for step in steps -%}
    {%- set idx = loop.index -%}
    {%- set isDisabled = step.disabled | default(false) -%}
    {%- set state =
      isDisabled         ? 'disabled' :
      (idx <  currentStep ? 'completed' :
      (idx == currentStep ? 'current' : 'upcoming'))
    -%}
    <li
      id="{{ htmlId }}-step-{{ idx }}"
      class="cremona-stepper__step"
      data-stepper-target="step"
      data-step-index="{{ idx }}"
      data-state="{{ state }}"
      {%- if state == 'current' %} aria-current="step"{% endif -%}
    >
      <span class="cremona-stepper__indicator" aria-hidden="true">
        <span class="cremona-stepper__indicator-number">{{ idx }}</span>
        <span class="cremona-stepper__indicator-check"></span>
      </span>
      <div class="cremona-stepper__text">
        <span class="cremona-stepper__label">{{ step.label }}</span>
        {%- if step.description is defined and step.description -%}
          <span class="cremona-stepper__description">{{ step.description }}</span>
        {%- endif -%}
      </div>
    </li>
  {%- endfor -%}
</ol>
