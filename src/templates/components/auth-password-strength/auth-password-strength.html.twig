{#-
  Auth-PasswordStrength — password field with live strength meter (Ring 3).

  Composable mini-block — drops INTO Auth-Register / Auth-ResetPassword
  form bodies (replaces the bare password Field). NOT a full-page pattern.

  Composes :
    - Field + Label + Input (Ring 1) — the password input.
    - Progress (Ring 1) via compose-by-class — kit renders `<progress
      class="cremona-progress">` directly so it can stamp data-target
      on the element (Progress primitive doesn't expose a target-attr
      param). Mirror Auth-SocialButtons compose-by-class doctrine.

  Stimulus controller : `password-strength` (~110 lines). Lazy-loads
  zxcvbn-ts on first keystroke. 3-tier score → variant mapping
  (kit-owned doctrine).

  Events emitted :
    - password-strength:mount    — on connect()
    - password-strength:change   — on every score change ; detail.valid

  See `docs/specs/ring3/Auth-PasswordStrength.md` for the full spec.
-#}

{%- set htmlId          = htmlId          | default('cremona-auth-password-strength-' ~ random()) -%}
{%- set name            = name            | default('password') -%}
{%- set label           = label           | default('theme.auth.password-strength.input-label'|trans) -%}
{%- set placeholder     = placeholder     | default('theme.auth.password-strength.input-placeholder'|trans) -%}
{%- set passwordHelp    = passwordHelp    | default('theme.auth.password-strength.help'|trans) -%}
{%- set error           = error           | default(null) -%}
{%- set value           = value           | default(null) -%}
{%- set required        = required        | default(true) -%}
{%- set autocomplete    = autocomplete    | default('new-password') -%}
{%- set minScore        = minScore        | default(2) -%}
{%- set debounceMs      = debounceMs      | default(150) -%}
{%- set meterAriaLabel  = meterAriaLabel  | default('theme.auth.password-strength.aria.meter'|trans) -%}
{%- set initialHint     = initialHint     | default('theme.auth.password-strength.tier.empty'|trans) -%}
{%- set className       = className       | default('') -%}

{%- set _wrapClasses = ['cremona-auth-password-strength'] -%}
{%- if className -%}{%- set _wrapClasses = _wrapClasses | merge([className]) -%}{%- endif -%}

{%- set _hintId  = htmlId ~ '-hint' -%}

<div
  class="{{ _wrapClasses | join(' ') }}"
  data-controller="password-strength"
  data-password-strength-min-score-value="{{ minScore }}"
  data-password-strength-debounce-ms-value="{{ debounceMs }}"
>
  {% embed '@cremona/components/field/field.html.twig' with {
    label: label,
    htmlId: htmlId,
    required: required,
    help: passwordHelp,
    error: error,
    className: '',
  } %}
    {% block control %}
      {% include '@cremona/components/input/input.html.twig' with {
        type: 'password',
        htmlId: fieldHtmlId,
        name: name,
        value: value,
        placeholder: placeholder,
        autocomplete: autocomplete,
        required: fieldRequired,
        invalid: fieldInvalid,
        describedBy: (fieldDescribedBy ? fieldDescribedBy ~ ' ' : '') ~ _hintId,
        attrs: {
          'data-password-strength-target': 'input',
          'data-action': 'input->password-strength#evaluate',
        },
      } only %}
    {% endblock %}
  {% endembed %}

  {% include '@cremona/components/progress/progress.html.twig' with {
    value: 0,
    max: 100,
    size: 'sm',
    variant: 'danger',
    attrs: {
      'data-password-strength-target': 'meter',
      'aria-label': meterAriaLabel,
    },
  } only %}

  <p
    class="cremona-auth-password-strength__hint"
    data-password-strength-target="hint"
    id="{{ _hintId }}"
    aria-live="polite"
  >{{ initialHint }}</p>
</div>
