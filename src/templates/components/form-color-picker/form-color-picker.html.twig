{#-
  Form-ColorPicker — color selection input (HSV/HSL/RGB/HEX + preset palette + optional alpha).

  Per Forms family doctrine (Form-WithSteps.md §1) :
    - Field primitive (Ring 1) is the composition keystone.
    - Cross-controller compose with Popover Ring 2 — `data-controller="popover color-picker"`
      on the wrapper (mirror DatePicker S2.7 + Form-AddressAutocomplete S3.3a-1 verbatim).
    - Coloris library lazy-loaded on first popover:open per ADR-0025 (9e cascade).

  Parameters:
    htmlId          (string,  optional) — auto-generated.
    label           (string,  required) — visible Field label.
    name            (string,  required) — form field name.
    help            (string,  optional) — help text below the widget.
    error           (string,  optional) — error message.
    required        (bool,    optional) — default false.
    defaultColor    (string,  optional) — initial hex value (default '#000000').
    alpha           (bool,    optional) — opt-in transparency slider (default false).
    swatches        (array,   optional) — preset palette of hex strings (default []).
    format          (string,  optional) — 'hex' | 'rgb' | 'hsl' (default 'hex').
    placement       (string,  optional) — Popover placement (default 'bottom-start').
    className       (string,  optional)

  Events emitted on the wrapper :
    color-picker:mount   { value }
    color-picker:ready
    color-picker:change  { value }

  Usage:

    {% include '@theme/components/form-color-picker/form-color-picker.html.twig' with {
      label: 'theme.form.color-picker.label.brand'|trans,
      name: 'brand_color',
      defaultColor: '#6366F1',
      swatches: ['#000000', '#FFFFFF', '#EF4444', '#10B981', '#3B82F6'],
    } %}
-#}

{%- set htmlId       = htmlId       | default('theme-form-color-' ~ random()) -%}
{%- set required     = required     | default(false) -%}
{%- set defaultColor = defaultColor | default('#000000') -%}
{%- set alpha        = alpha        | default(false) -%}
{%- set swatches     = swatches     | default([]) -%}
{%- set format       = format       | default('hex') -%}
{%- set placement    = placement    | default('bottom-start') -%}
{%- set className    = className    | default('') -%}

{%- set isInvalid = error is defined and error -%}
{%- set _classes = ['theme-field', 'theme-form-color-picker'] -%}
{%- if isInvalid -%}{%- set _classes = _classes | merge(['theme-field--invalid']) -%}{%- endif -%}
{%- if className -%}{%- set _classes = _classes | merge([className]) -%}{%- endif -%}

{%- set describedByIds = [] -%}
{%- if help -%}{%- set describedByIds = describedByIds | merge([htmlId ~ '-help']) -%}{%- endif -%}
{%- if isInvalid -%}{%- set describedByIds = describedByIds | merge([htmlId ~ '-error']) -%}{%- endif -%}

{%- set _wrapClasses    = ['theme-popover', 'theme-form-color-picker__wrap'] -%}
{%- set _triggerClasses = ['theme-button', 'theme-form-color-picker__trigger'] -%}

<div
  class="{{ _classes | join(' ') }}"
  data-controller="popover color-picker"
  data-popover-placement-value="{{ placement }}"
  data-popover-offset-value="4"
  data-color-picker-alpha-value="{{ alpha ? 'true' : 'false' }}"
  data-color-picker-default-color-value="{{ defaultColor }}"
  data-color-picker-format-value="{{ format }}"
  {%- if swatches | length %} data-color-picker-swatches-value="{{ swatches | json_encode | e('html_attr') }}"{% endif -%}
>
  {% include '@theme/components/label/label.html.twig' with {
    content: label,
    htmlFor: htmlId ~ '-input',
    required: required,
    requiredAriaText: 'theme.form.color-picker.required'|trans,
  } only %}

  <div class="{{ _wrapClasses | join(' ') }}">
    <button
      type="button"
      class="{{ _triggerClasses | join(' ') }}"
      data-popover-target="trigger"
      data-color-picker-target="trigger"
      data-variant="outline"
      aria-label="{{ 'theme.form.color-picker.aria.trigger'|trans }}"
      aria-haspopup="dialog"
    >
      <span
        class="theme-form-color-picker__preview"
        data-color-picker-target="preview"
        style="background-color: {{ defaultColor }};"
        aria-hidden="true"
      ></span>
      {% include '@theme/components/input/input.html.twig' with {
        type: 'text',
        htmlId: htmlId ~ '-input',
        name: name,
        value: defaultColor,
        placeholder: 'theme.form.color-picker.placeholder.hex'|trans,
        required: required,
        invalid: isInvalid,
        describedBy: describedByIds | length ? describedByIds | join(' ') : null,
        className: 'theme-form-color-picker__hex',
        attrs: { 'data-color-picker-target': 'input' },
      } only %}
    </button>

    <div
      class="theme-popover__content theme-form-color-picker__panel"
      data-popover-target="content"
      role="dialog"
      aria-label="{{ 'theme.form.color-picker.aria.trigger'|trans }}"
    >
      {#- Coloris injects its picker UI inside this content area on first popover:open. -#}
    </div>
  </div>

  {%- if help -%}
    <p class="theme-field__help" id="{{ htmlId }}-help">{{ help }}</p>
  {%- endif -%}
  {%- if isInvalid -%}
    <p class="theme-field__error" id="{{ htmlId }}-error">{{ error }}</p>
  {%- endif -%}
</div>
