{#-
  Onboarding-ProductTour — anchored hotspots + popover tour (Ring 3 S3.2).

  Composes the `product-tour` Stimulus controller (NEW — 3rd Ring 3 ctrl).
  Lazy-loads driver.js v1.x on first start() per ADR-0020.

  Parameters:
    htmlId        (string, optional)
    triggerLabel  (string, required)  — trigger button microcopy
    steps         (array, required)   — [{element, popover: {title, description}}]
    autoStart     (bool, optional)    — default false
    showProgress  (bool, optional)    — default true
-#}

{%- set htmlId       = htmlId       | default('theme-onboarding-product-tour-' ~ random()) -%}
{%- set autoStart    = autoStart    | default(false) -%}
{%- set showProgress = showProgress | default(true) -%}

<div class="theme-onboarding-product-tour"
     id="{{ htmlId }}"
     data-controller="product-tour"
     data-product-tour-steps-value="{{ steps|json_encode }}"
     data-product-tour-auto-start-value="{{ autoStart ? 'true' : 'false' }}"
     data-product-tour-show-progress-value="{{ showProgress ? 'true' : 'false' }}"
     data-product-tour-state="idle">
  {% include '@theme/components/button/button.html.twig' with {
    label: triggerLabel,
    variant: 'primary',
    className: 'theme-onboarding-product-tour__trigger',
    attrs: {
      'data-product-tour-target': 'trigger',
      'data-action': 'click->product-tour#start',
    },
  } only %}
</div>
