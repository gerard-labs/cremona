{
  "name": "@gerard/cremona",
  "version": "0.2.6",
  "private": true,
  "description": "Universal tokenized UI kit (Tailwind v4 + Stimulus + Twig). Symfony-first, portable to React/Vue/Drupal/static.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.1",
  "main": "./dist/cremona.js",
  "module": "./dist/cremona.js",
  "style": "./dist/cremona.css",
  "exports": {
    ".": {
      "import": "./dist/cremona.js",
      "style": "./dist/cremona.css"
    },
    "./cremona.css": "./dist/cremona.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "histoire dev",
    "build": "vite build && vite build --mode css",
    "histoire:dev": "histoire dev",
    "histoire:build": "histoire build",
    "histoire:preview": "histoire preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:a11y": "playwright test --config=playwright.a11y.config.js",
    "test:visual": "playwright test --config=playwright.visual.config.js",
    "test:e2e": "playwright test --config=playwright.e2e.config.js",
    "lint": "pnpm /^lint:/",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:js": "eslint 'src/**/*.js' 'tools/**/*.js' 'tests/**/*.js'",
    "lint:logical": "node tools/check-logical-css.js",
    "lint:i18n": "node tools/check-i18n.js",
    "lint:manifest": "node tools/check-manifest.js",
    "lint:tokens": "node tools/check-tokens.js",
    "lint:composition": "node tools/check-composition.js",
    "format": "prettier --write 'src/**/*.{js,css,md}'"
  },
  "dependencies": {
    "apexcharts": "^4.5.0",
    "@floating-ui/dom": "^1.7.6",
    "@hotwired/stimulus": "^3.2.2",
    "@melloware/coloris": "^0.25.0",
    "@yaireo/tagify": "^4.32.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "dayjs": "^1.11.13",
    "driver.js": "^1.3.1",
    "filepond": "^4.32.0",
    "filepond-plugin-file-validate-size": "^2.2.8",
    "filepond-plugin-file-validate-type": "^1.2.9",
    "filepond-plugin-image-preview": "^4.6.12",
    "intl-tel-input": "^25.0.0",
    "signature_pad": "^5.0.0",
    "sortablejs": "^1.15.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.16.0",
    "@histoire/plugin-vue": "^0.17.17",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "happy-dom": "^15.11.6",
    "histoire": "^0.17.17",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-use-logical": "^2.1.2",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "wcag-contrast": "^3.0.0"
  }
}
