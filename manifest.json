      "ring": 2
    },
    "drag:SortableJS": {
      "decision": "chosen",
      "ring": 4,
      "note": "PM-Board / PM-Backlog — lazy-load on mount per ADR-0045 (10e lazy adapter cascade after ADR-0011/0012/0013/0018/0020/0022/0023/0024/0025). sortablejs ^1.15.0 — vanilla JS no deps, touch + mouse + pointer events normalized, cross-list drag (kanban via group config), drag handle opt-in (.theme-sortable-handle), animation honors prefers-reduced-motion. Keyboard reorder accommodation (Space + Arrow keys + Escape) wired sync per kit doctrine."
    },
    "tags:Tagify": {
      "decision": "chosen",
      "ring": 3,
      "note": "Form-TagInput — lazy-load on mount per ADR-0023 (7e cascade). @yaireo/tagify ^4.x — chip render + paste-multi + backspace-pop + optional whitelist autocomplete + RTL-safe. Plurals via Intl.PluralRules per 15-i18n-and-rtl §Plurals."
    },
    "phone:intl-tel-input": {
      "decision": "chosen",
      "ring": 3,
      "note": "Form-PhoneInput — lazy-load on first focus per ADR-0022 (6e cascade ; mirror ADR-0018 first-keystroke variant verbatim). intl-tel-input ^25.x — country picker + flags + 245-country metadata + format-as-you-type per libphonenumber + RTL-safe flag rendering. Largest lazy chunk of S3.3a-2 (~25 kB)."
    },
    "mask:IMask": {
      "decision": "candidate",
      "ring": 2
    },
    "slider:noUiSlider": {
      "decision": "candidate",
      "ring": 2
    },
    "signature:signature_pad": {
